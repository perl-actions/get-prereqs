{
  "name": "get-prereqs",
  "version": "2.0.0",
  "description": "Get prereqs for local dist",
  "main": "src/get-prereqs.mjs",
  "type": "module",
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "mocha",
    "build": "./build-release.mjs",
    "preversion": "npm test && npm run lint",
    "version": "npm run build && ./prep-changelog && git add -A dist CHANGELOG.md",
    "postversion": "git push origin HEAD && git push origin v$(npm pkg get version --workspaces=false | tr -d \\\")"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/perl-actions/get-prereqs.git"
  },
  "keywords": [],
  "author": "Graham Knop <haarg@haarg.org>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/perl-actions/get-prereqs/issues"
  },
  "homepage": "https://github.com/perl-actions/get-prereqs#readme",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "js-yaml": "^4.1.1",
    "minimist": "^1.2.8",
    "peggy": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@peggyjs/eslint-plugin": "^2.1.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "chai": "^6.2.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-mocha": "^11.2.0",
    "esmock": "^2.7.5",
    "globals": "^17.6.0",
    "mocha": "^v12.0.0-beta-9.3"
  }
}
